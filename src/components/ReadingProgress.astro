<div class="reading-progress" aria-hidden="true">
  <div class="reading-progress__bar" data-reading-progress-bar></div>
</div>

<script>
  const bar = document.querySelector('[data-reading-progress-bar]')
  const content = document.querySelector('[data-reading-progress-content]')

  if (bar instanceof HTMLElement && content instanceof HTMLElement) {
    let start = 0
    let end = 1
    let frame = 0

    const clamp = (value: number) => Math.min(1, Math.max(0, value))

    const update = () => {
      frame = 0

      const progress = clamp((window.scrollY - start) / (end - start))
      bar.style.transform = `scaleX(${progress})`
      bar.style.opacity = progress > 0.002 ? '1' : '0'
    }

    const scheduleUpdate = () => {
      if (frame) {
        return
      }

      frame = window.requestAnimationFrame(update)
    }

    const measure = () => {
      const viewportHeight =
        window.innerHeight || document.documentElement.clientHeight
      const contentTop = content.getBoundingClientRect().top + window.scrollY
      const contentHeight = content.scrollHeight
      const pageEnd = Math.max(
        0,
        document.documentElement.scrollHeight - viewportHeight,
      )
      const rawEnd =
        contentHeight > viewportHeight
          ? contentTop + contentHeight - viewportHeight
          : contentTop + contentHeight

      start = Math.min(Math.max(0, contentTop), pageEnd)
      end = Math.min(Math.max(start + 1, rawEnd), pageEnd || start + 1)

      scheduleUpdate()
    }

    window.addEventListener('scroll', scheduleUpdate, { passive: true })
    window.addEventListener('resize', measure)
    window.addEventListener('load', measure)

    if ('ResizeObserver' in window) {
      const observer = new ResizeObserver(measure)
      observer.observe(content)
    }

    measure()
  }
</script>

<style>
  .reading-progress {
    position: fixed;
    top: env(safe-area-inset-top, 0);
    right: 0;
    left: 0;
    z-index: 60;
    height: 0.1875rem;
    background: transparent;
    pointer-events: none;
  }

  .reading-progress__bar {
    width: 100%;
    height: 100%;
    transform: scaleX(0);
    transform-origin: left center;
    background: linear-gradient(
      90deg,
      var(--color-green-600),
      var(--color-green-400)
    );
    opacity: 0;
    transition:
      transform 120ms ease-out,
      opacity 120ms ease-out;
  }

  @media (min-width: 48rem) {
    .reading-progress {
      height: 0.25rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .reading-progress__bar {
      transition: none;
    }
  }
</style>
